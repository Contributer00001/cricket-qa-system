# HuggingFace Authentication
HF_TOKEN=hf_your_read_token_here

# API key auth for /infer endpoint (leave blank to disable, dev mode)
API_KEY=your-key-here

# Model Configuration
BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LORA_REPO=Conqueror00001/qwen-ipl-lora

# Data Configuration
DEFAULT_MATCH_FILE=data/sample_match.json

# Device (mps for Mac M1/M2, cpu for others)
DEVICE=cpu
