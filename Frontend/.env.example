# Backend API URL.
# Development (default): leave this unset — the Vite dev server proxies /api
# to http://localhost:8000 automatically (see vite.config.ts).
#
# Production: set to the full base URL of your deployed backend, e.g.:
#   VITE_API_URL=https://api.your-domain.com
VITE_API_URL=http://localhost:8000

# Dev server port (default: 5173). Set to 3000 if you prefer that port.
VITE_PORT=5173
